# A-Shares Master 环境变量配置
# 复制此文件为 .env 并填入实际值

# Iwencai API 密钥 (必需)
IWENCAI_BASE_URL=https://openapi.iwencai.com
IWENCAI_API_KEY=your_iwencai_apikey_here

# MX API 密钥 (必需)
MX_APIKEY=your_mx_apikey_here

# EM API 密钥 (必需)
EM_API_KEY=your_em_apikey_here

# 数据缓存目录 (可选，默认 /tmp/a_shares_cache)
DATA_CACHE_DIR=/tmp/a_shares_cache

# 日志级别 (可选，默认 INFO)
LOG_LEVEL=INFO
