# Default mode uses latest live online data from trusted upstreams.
IWENCAI_BASE_URL=https://openapi.iwencai.com
IWENCAI_API_KEY=
MX_APIKEY=
EM_API_KEY=

# Live data controls
A_SHARE_SKILL_OFFLINE_MODE=false
A_SHARE_SKILL_DATA_PATH=
A_SHARE_SKILL_LIVE_SOURCE=tencent
A_SHARE_SKILL_TIMEOUT_SECONDS=10
A_SHARE_SKILL_WATCHLIST=300750,002594,600519,000001,600036,601318,000333,002475,601899,300308
DATA_CACHE_DIR=/tmp/a_shares_cache
LOG_LEVEL=INFO

# Trading guardrails
MAX_POSITION_RATIO=0.5
MAX_SINGLE_POSITION=0.3
STOP_LOSS_RATIO=0.07
PROFIT_TARGET_MULTIPLIER=3
MIN_DAILY_TURNOVER_MILLION=50
